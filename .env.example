# Copy to .env and fill in values
# NEVER commit .env to git

# Database (Render PostgreSQL connection string)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/simployer_qa

# Redis (Upstash or Render Redis)
REDIS_URL=redis://default:password@host:6379

# Auth
SECRET_KEY=change-me-generate-a-real-secret

# Freshdesk
FRESHDESK_DOMAIN=simployer.freshdesk.com
FRESHDESK_API_KEY=your-freshdesk-api-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# App
CORS_ORIGINS=["https://your-app.onrender.com"]
ENVIRONMENT=production
SENTRY_DSN=
